{
  "version": 1,
  "kind": "miniapp-test-plan",
  "metadata": {
    "name": "placeholder-login-home",
    "draft": false,
    "source": {
      "type": "example",
      "prompt": "Login and verify that the home page becomes visible."
    },
    "planner": {
      "mode": "example",
      "notes": [
        "This example targets the placeholder runtime so it can be executed locally without a real mini program project."
      ]
    }
  },
  "environment": {
    "projectPath": ".",
    "wechatDevtoolPath": null,
    "testPort": 9420,
    "language": "en-US",
    "runtimeMode": "placeholder"
  },
  "execution": {
    "mode": "serial",
    "failFast": true
  },
  "steps": [
    {
      "id": "step-1",
      "type": "session.start",
      "input": {
        "projectPath": "."
      }
    },
    {
      "id": "step-2",
      "type": "page.read",
      "input": {}
    },
    {
      "id": "step-3",
      "type": "element.click",
      "input": {
        "locator": {
          "type": "id",
          "value": "login-button"
        }
      }
    },
    {
      "id": "step-4",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "page_path_equals",
          "expectedValue": "pages/home/index",
          "timeoutMs": 3000
        }
      }
    },
    {
      "id": "step-5",
      "type": "assert.pagePath",
      "input": {
        "expectedPath": "pages/home/index"
      }
    },
    {
      "id": "step-6",
      "type": "session.close",
      "input": {}
    }
  ]
}
