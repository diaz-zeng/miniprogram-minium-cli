{
  "version": 1,
  "kind": "miniapp-test-plan",
  "metadata": {
    "name": "demo-network-transfer-placeholder",
    "draft": false
  },
  "environment": {
    "projectPath": "../demo-miniapp",
    "wechatDevtoolPath": null,
    "testPort": 9420,
    "language": "en-US",
    "runtimeMode": "placeholder"
  },
  "execution": {
    "mode": "serial",
    "failFast": true
  },
  "steps": [
    {
      "id": "step-1",
      "type": "session.start",
      "input": {
        "projectPath": "../demo-miniapp",
        "initialPagePath": "/pages/bridge-lab/index"
      }
    },
    {
      "id": "step-2",
      "type": "network.listen.start",
      "input": {
        "listenerId": "transfer-network",
        "captureResponses": true
      }
    },
    {
      "id": "step-3",
      "type": "network.intercept.add",
      "input": {
        "ruleId": "download-mock",
        "matcher": {
          "resourceType": "download",
          "url": "https://service.invalid/reports/latest.bin",
          "method": "GET"
        },
        "behavior": {
          "action": "mock",
          "response": {
            "statusCode": 206,
            "headers": {
              "x-source": "mock"
            },
            "body": {
              "tempFilePath": "/tmp/mock-report.bin"
            }
          }
        }
      }
    },
    {
      "id": "step-4",
      "type": "file.upload",
      "input": {
        "url": "https://service.invalid/upload",
        "filePath": "/tmp/bridge-demo.png",
        "name": "artifact"
      }
    },
    {
      "id": "step-5",
      "type": "file.download",
      "input": {
        "url": "https://service.invalid/reports/latest.bin"
      }
    },
    {
      "id": "step-6",
      "type": "network.wait",
      "input": {
        "listenerId": "transfer-network",
        "event": "response",
        "timeoutMs": 1000,
        "matcher": {
          "resourceType": "download",
          "url": "https://service.invalid/reports/latest.bin",
          "statusCode": 206
        }
      }
    },
    {
      "id": "step-7",
      "type": "assert.networkRequest",
      "input": {
        "listenerId": "transfer-network",
        "matcher": {
          "resourceType": "upload",
          "method": "POST",
          "url": "https://service.invalid/upload"
        },
        "count": 1
      }
    },
    {
      "id": "step-8",
      "type": "assert.networkResponse",
      "input": {
        "listenerId": "transfer-network",
        "matcher": {
          "resourceType": "download",
          "url": "https://service.invalid/reports/latest.bin",
          "statusCode": 206,
          "responseBody": {
            "tempFilePath": "/tmp/mock-report.bin"
          }
        },
        "count": 1
      }
    },
    {
      "id": "step-9",
      "type": "network.intercept.clear",
      "input": {}
    },
    {
      "id": "step-10",
      "type": "session.close",
      "input": {}
    }
  ]
}
