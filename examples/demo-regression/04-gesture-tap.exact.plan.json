{
  "version": 1,
  "kind": "miniapp-test-plan",
  "metadata": {
    "name": "demo-gesture-tap-exact",
    "draft": false
  },
  "environment": {
    "projectPath": "../demo-miniapp",
    "wechatDevtoolPath": null,
    "testPort": 9420,
    "language": "en-US",
    "runtimeMode": "auto"
  },
  "execution": {
    "mode": "serial",
    "failFast": true
  },
  "steps": [
    {
      "id": "step-1",
      "type": "session.start",
      "input": {
        "projectPath": "../demo-miniapp",
        "initialPagePath": "/pages/gesture/index"
      }
    },
    {
      "id": "step-2",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "gesture-title"
        },
        "expectedText": "Gesture Lab"
      }
    },
    {
      "id": "step-3",
      "type": "gesture.touchTap",
      "input": {
        "pointerId": 0,
        "locator": {
          "type": "id",
          "value": "gesture-target"
        }
      }
    },
    {
      "id": "step-4",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "gesture-status-text"
        },
        "expectedText": "Gesture status: tapped"
      }
    },
    {
      "id": "step-5",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "gesture-tap-count-text"
        },
        "expectedText": "Tap count: 1"
      }
    },
    {
      "id": "step-6",
      "type": "session.close",
      "input": {}
    }
  ]
}
