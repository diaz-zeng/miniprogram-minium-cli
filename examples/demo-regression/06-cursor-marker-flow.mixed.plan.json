{
  "version": 1,
  "kind": "miniapp-test-plan",
  "metadata": {
    "name": "demo-cursor-marker-flow-mixed",
    "draft": false
  },
  "environment": {
    "projectPath": "../demo-miniapp",
    "wechatDevtoolPath": null,
    "testPort": 9420,
    "language": "en-US",
    "runtimeMode": "auto"
  },
  "execution": {
    "mode": "serial",
    "failFast": true
  },
  "steps": [
    {
      "id": "step-1",
      "type": "session.start",
      "input": {
        "projectPath": "../demo-miniapp",
        "initialPagePath": "/pages/cursor-lab/index"
      }
    },
    {
      "id": "step-2",
      "type": "element.query",
      "input": {
        "locator": {
          "type": "text",
          "value": "place a marker"
        }
      }
    },
    {
      "id": "step-3",
      "type": "gesture.touchStart",
      "input": {
        "pointerId": 0,
        "locator": {
          "type": "id",
          "value": "cursor-drag-button"
        }
      }
    },
    {
      "id": "step-4",
      "type": "artifact.screenshot",
      "input": {
        "prefix": "cursor-armed"
      }
    },
    {
      "id": "step-5",
      "type": "gesture.touchMove",
      "input": {
        "pointerId": 0,
        "x": 180,
        "y": 460
      }
    },
    {
      "id": "step-6",
      "type": "gesture.touchTap",
      "input": {
        "pointerId": 1,
        "locator": {
          "type": "id",
          "value": "marker-drop-button"
        }
      }
    },
    {
      "id": "step-7",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "element_visible",
          "locator": {
            "type": "text",
            "value": "Marker count: 1"
          },
          "timeoutMs": 2000
        }
      }
    },
    {
      "id": "step-8",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "last-marker-text"
        },
        "expectedText": "Last marker: 180,460"
      }
    },
    {
      "id": "step-9",
      "type": "artifact.screenshot",
      "input": {
        "prefix": "first-marker"
      }
    },
    {
      "id": "step-10",
      "type": "gesture.touchMove",
      "input": {
        "pointerId": 0,
        "x": 260,
        "y": 540
      }
    },
    {
      "id": "step-11",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "element_visible",
          "locator": {
            "type": "text",
            "value": "Cursor position: 260,540"
          },
          "timeoutMs": 2000
        }
      }
    },
    {
      "id": "step-12",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "cursor-position-text"
        },
        "expectedText": "Cursor position: 260,540"
      }
    },
    {
      "id": "step-13",
      "type": "artifact.screenshot",
      "input": {
        "prefix": "cursor-relocated"
      }
    },
    {
      "id": "step-14",
      "type": "gesture.touchTap",
      "input": {
        "pointerId": 1,
        "locator": {
          "type": "id",
          "value": "marker-drop-button"
        }
      }
    },
    {
      "id": "step-15",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "element_visible",
          "locator": {
            "type": "text",
            "value": "Marker count: 2"
          },
          "timeoutMs": 2000
        }
      }
    },
    {
      "id": "step-16",
      "type": "artifact.screenshot",
      "input": {
        "prefix": "second-marker"
      }
    },
    {
      "id": "step-17",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "marker-count-text"
        },
        "expectedText": "Marker count: 2"
      }
    },
    {
      "id": "step-18",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "last-marker-text"
        },
        "expectedText": "Last marker: 260,540"
      }
    },
    {
      "id": "step-19",
      "type": "gesture.touchEnd",
      "input": {
        "pointerId": 0
      }
    },
    {
      "id": "step-20",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "element_visible",
          "locator": {
            "type": "text",
            "value": "Active touches: 0"
          },
          "timeoutMs": 2000
        }
      }
    },
    {
      "id": "step-21",
      "type": "element.click",
      "input": {
        "locator": {
          "type": "text",
          "value": "review board"
        }
      }
    },
    {
      "id": "step-22",
      "type": "wait.for",
      "input": {
        "condition": {
          "kind": "page_path_equals",
          "expectedValue": "pages/review-board/index",
          "timeoutMs": 2000
        }
      }
    },
    {
      "id": "step-23",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "review-board-title"
        },
        "expectedText": "Review Board"
      }
    },
    {
      "id": "step-24",
      "type": "assert.elementText",
      "input": {
        "locator": {
          "type": "id",
          "value": "review-marker-summary-text"
        },
        "expectedText": "Marker summary: 2 markers"
      }
    },
    {
      "id": "step-25",
      "type": "session.close",
      "input": {}
    }
  ]
}
